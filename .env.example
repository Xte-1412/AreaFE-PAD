# ============================================================
# SIPELITA Frontend — Environment Variables Example
# Salin file ini menjadi .env.local dan isi sesuai environment
# ============================================================

# URL Backend API (Laravel / Koyeb)
# PENTING: Jangan tambahkan /api di akhir URL.
#   ✅ Benar : NEXT_PUBLIC_API_URL=https://your-api.koyeb.app
#   ❌ Salah : NEXT_PUBLIC_API_URL=https://your-api.koyeb.app/api
#
# Semua path /api sudah ditambahkan otomatis oleh masing-masing request.
# Jika URL diisi dengan trailing /api, semua request akan menjadi /api/api/...
# dan gagal dengan HTTP 404.
NEXT_PUBLIC_API_URL=http://localhost:8000
